load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "greeter",
    srcs = ["greeter.go"],
    importpath = "github.com/aspect-build/bazel-examples/hermetic_tests/go/greeter",
    visibility = ["//:__subpackages__"],
)

go_test(
    name = "greeter_test",
    size = "small",
    srcs = ["greeter_test.go"],
    data = ["testdata/expected_greeting.txt"],
    embed = [":greeter"],
)

go_library(
    name = "go",
    srcs = ["greeter.go"],
    importpath = "github.com/aspect-build/bazel-examples/hermetic_tests/go",
    visibility = ["//visibility:public"],
)

go_test(
    name = "go_test",
    srcs = ["greeter_test.go"],
    data = glob(["testdata/**"]),
    embed = [":go"],
)
